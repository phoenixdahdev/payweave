{
  "name": "payweave-monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "changeset": "changeset",
    "version": "changeset version && node packages/payweave/scripts/sync-version.mjs",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@payweave/eslint-config": "workspace:*",
    "@payweave/typescript-config": "workspace:*",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.10.4",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "@types/node": "26.1.1"
    }
  }
}
